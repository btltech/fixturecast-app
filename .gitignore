!ml_engine/trained_models/*.pkl
ml_engine/trained_models/meta_model.pkl

# Exclude feedback logs (can get large)
ml_engine/trained_models/feedback/

# Large training data files (models are pre-trained)
data/historical/all_leagues_combined.json
data/historical/league_*_all.json
.env
logs/

# Runtime log files
*.log
backtest_run_*.log

