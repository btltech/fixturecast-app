# Security headers for fixturecast.com
/*
  # Content Security Policy - strict for SPA
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://fixturecast.com https://ai-assistant-widgets.pages.dev https://75de0ed2.ai-assistant-widgets.pages.dev; style-src 'self' 'unsafe-inline' https://fixturecast.com https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https: https://fonts.gstatic.com; connect-src 'self' https://fixturecast.com https://*.railway.app https://fonts.googleapis.com https://media.api-sports.io https://*.ai-assistant-widgets.pages.dev https://ai-assistant-simple.btltech.workers.dev wss://ai-assistant-cloudflare.btltech.workers.dev; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

  # HTTP Strict Transport Security
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Prevent MIME sniffing
  X-Content-Type-Options: nosniff

  # Referrer Policy
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions Policy
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()

  # X-Frame-Options (fallback for CSP)
  X-Frame-Options: DENY

  # Restrict CORS to self (if applicable)
  Access-Control-Allow-Origin: https://fixturecast.com
  Access-Control-Allow-Methods: GET, POST, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization

# HTML shell - always revalidate (304 = ~100 bytes, costs nothing)
/index.html
  Cache-Control: no-cache

# Service worker - always revalidate so new deploys register immediately
/sw.js
  Cache-Control: no-cache

# Vite hashed assets - cache forever (filename changes on every build)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static images & icons - cache 1 week
/icons/*
  Cache-Control: public, max-age=604800
/default-og.png
  Cache-Control: public, max-age=604800
/favicon.svg
  Cache-Control: public, max-age=604800
